#!/bin/sh

# ask for root using pkexec 
if [ "$(id -u)" -ne 0 ]; then #id not 0 means not root
    exec pkexec "$0" "$@"
fi

command -v yadbattery >/dev/null 2>&1 || { echo "cant find script in path,exiting"; exit 1; } #check script existence

#conditions for logging (touching lockfile followed by script only works too.)
if [ ! -f /tmp/sulockfile ]; then
touch /tmp/sulockfile
echo "no lockfile detected,wrote lock"
yadbattery
elif [ -f /tmp/sulockfile ]; then
echo "lockfile exists...!,countinue suspend"
yadbattery
else
echo "cant access file status/unknown condition, exiting" #investigate lockfile attributes/permissions of filesystem
exit 1 
fi
