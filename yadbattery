#!/bin/bash

#find the battery using sysfs or error out
#may fail for multi-battery (please help in testing and reporting) or if your system labels power supply as BAT (unlikely)
for B in /sys/class/power_supply/BAT?; do
    [ -d "$B" ] && BATTERY_PATH="$B" && break
done
[ -z "$BATTERY_PATH" ] && echo "didnt find Battery path" && exit 1   #exit if not found (need to add a error message)

# Check dependencies
command -v bc >/dev/null 2>&1 || { echo "bc is required"; exit 1; }
command -v yad >/dev/null 2>&1 || { echo "yad is required"; exit 1; }
command -v upower >/dev/null 2>&1 || { echo "upower is required"; exit 1; }


#getting the xauth  magic-cookie to display the yad dialogue //sorted according to current graphical user
#have noticed missing dialogues in multi-user need cause and fix
for user in $(who | grep "(:[0-9]" | cut -d' ' -f1 | head -1); do
    cp "/home/$user/.Xauthority" /root/.Xauthority.tmp 2>/dev/null && {
        export XAUTHORITY=/root/.Xauthority.tmp
        break
    }
done


#set values
LOW=10
WARN=20

DRAIN_RATE_WATT=2.5  
SAFETY_PERCENT=5

TOTAL_CAPACITY_WH=$(upower -i /org/freedesktop/UPower/devices/battery_BAT1 | grep -P -o 'energy-full:\s*\K[\d.]+\s') #need no dependency way to get Wh (critical...!)




# ----------------
#function declarations

battery_action(){

#no dialogue countdown at critical battery
if [ "$LEVEL" -le "$LOW" ] && [ "$STATUS" = "Discharging" ]; then
systemctl hibernate -i &&  rm -f /tmp/sulockfile && exit 0
#hibern && rm -f /tmp/sulockfile && exit 0  #custom hibernate script
fi

# Show non-interactive progress dialog that auto-closes after seconds
(
    for i in $(seq 10 -1 1); do
        percent=$(( (10-i)*100/10 ))
        echo "$percent"
        echo "# Sleeping in $i seconds (Battery: $LEVEL%)"
        sleep 1
    done
) | yad --progress \
    --title="Low Battery: $LEVEL%" \
    --text="Automatic Sleep...Connect power to terminate" \
    --timeout=10 \
    --no-cancel \
    --width=300 \
    --undecorated \
    --no-buttons \
    --auto-close

get_battery_info #check if plugged-in else hibernate

if [ "$LEVEL" -le "$LOW" ] && [ "$STATUS" = "Discharging" ]; then
systemctl hibernate -i &&  rm -f /tmp/sulockfile && exit 0 #rationale:if the person was present would have plugged-in (assumption) prevent unnecesary hibernate
else
rm -f /tmp/sulockfile #charger connected so remove looptrigger
#hibern  #custom hibernate script to manage chromium hang
fi
}

#old percent calculation currently unused
#_________________________
get_battery_percent() {
    local capacity_file="$BATTERY_PATH/capacity"
    if [[ -f "$capacity_file" ]]; then
        cat "$capacity_file"
    else
        # Fallback calculation
        local energy_now=$(cat "$BATTERY_PATH/charge_now" 2>/dev/null || echo 0)
        local energy_full=$(cat "$BATTERY_PATH/charge_full_design" 2>/dev/null || echo 0)
        if [[ $energy_full -gt 0 ]]; then
            echo $(( energy_now * 100 / energy_full ))
        else
            echo 0
        fi
    fi
}
