#!/bin/bash

#find the battery using sysfs or error out
#may fail for multi-battery (please help in testing and reporting) or if your system labels power supply as BAT (unlikely)
for B in /sys/class/power_supply/BAT?; do
    [ -d "$B" ] && BATTERY_PATH="$B" && break
done
[ -z "$BATTERY_PATH" ] && echo "didnt find Battery path" && exit 1   #exit if not found (need to add a error message)

# Check dependencies
command -v bc >/dev/null 2>&1 || { echo "bc is required"; exit 1; }
command -v yad >/dev/null 2>&1 || { echo "yad is required"; exit 1; }
command -v upower >/dev/null 2>&1 || { echo "upower is required"; exit 1; }


#getting the xauth  magic-cookie to display the yad dialogue //sorted according to current graphical user
#have noticed missing dialogues in multi-user need cause and fix
for user in $(who | grep "(:[0-9]" | cut -d' ' -f1 | head -1); do
    cp "/home/$user/.Xauthority" /root/.Xauthority.tmp 2>/dev/null && {
        export XAUTHORITY=/root/.Xauthority.tmp
        break
    }
done


#solid set values
LOW=15
WARN=20
SAFETY_PERCENT=10


# ----------------
#function declarations


#refresh dynamic values when needed
refresh_values(){
TOTAL_CAPACITY_WH=$(upower -i /org/freedesktop/UPower/devices/battery_BAT1 | grep -P -o 'energy-full:\s*\K[\d.]+\s') #need no dependency way to get Wh (critical...!)
DRAIN_RATE_WATT=$(upower -i /org/freedesktop/UPower/devices/battery_BAT1 | grep -P -o 'energy-rate:\s*\K[\d.]+')  #May becomes zero at times (1.when charger disconnected)
if [[ -z "$DRAIN_RATE_WATT" ]] || (( $(echo "$DRAIN_RATE_WATT <= 0" | bc -l) )); then #bc for float calculation but spawns a subshell (need faster impl)
        DRAIN_RATE_WATT=10.0  # Conservative fallback to prevent crash (optional another way for dynamism (portability:option))
    fi
}

battery_action(){
#no dialogue countdown at critical battery
get_battery_info
if [ "$LEVEL" -le "$LOW" ] && [ "$STATUS" = "Discharging" ]; then
rm -f /tmp/sulockfile && systemctl hibernate -i
exit 0
#hibern && rm -f /tmp/sulockfile && exit 0  #custom hibernate script
#fi
elif [ "$LEVEL" -le "$WARN" ] && [ "$STATUS" = "Discharging" ] && [[ ! -f /tmp/sulockfile ]]; then #no dialogue durin a suspend run
# Show non-interactive progress dialog that auto-closes after seconds
(
    for i in $(seq 10 -1 1); do
        percent=$(( (10-i)*100/10 ))
        echo "$percent"
        echo "# Sleeping in $i seconds (Battery: $LEVEL%)"
        sleep 1
    done
) | yad --progress \
    --title="Low Battery: $LEVEL%" \
    --text="Automatic Sleep...Connect power to terminate" \
    --timeout=10 \
    --no-cancel \
    --width=300 \
    --undecorated \
    --no-buttons \
    --auto-close

fi

get_battery_info #check if plugged-in else hibernate
sleep 1

if [ "$LEVEL" -le "$WARN" ] && [ "$STATUS" = "Discharging" ]; then
[[ -f /tmp/sulockfile ]] && echo "Error :lock file detected at this stage?,removing for safety" && rm -r /tmp/sulockfile
systemctl hibernate -i && exit 0 #rationale:if the person was present would have plugged-in (assumption) prevent unnecesary hibernate 
#also this wont(shoudnt) run in a suspend loop so no lockfile removals needed
#hibern  #custom hibernate script to manage chromium hang
fi
}

#old percent calculation currently unused
#_________________________
get_battery_percent() {
    local capacity_file="$BATTERY_PATH/capacity"
    if [[ -f "$capacity_file" ]]; then
        cat "$capacity_file"
    else
        # Fallback calculation
        local energy_now=$(cat "$BATTERY_PATH/charge_now" 2>/dev/null || echo 0)
        local energy_full=$(cat "$BATTERY_PATH/charge_full_design" 2>/dev/null || echo 0)
        if [[ $energy_full -gt 0 ]]; then
            echo $(( energy_now * 100 / energy_full ))
        else
            echo 0
        fi
    fi
}
#_________________________________


#current capacity and status logic
#-----------------
get_battery_info() {
    LEVEL=$(cat "$BATTERY_PATH/capacity")
    STATUS=$(cat "$BATTERY_PATH/status")
}
#-----------------

calculate_delay() {
#refresh_values #prevent unnecessary calls + mock support + logging (how?)
    local percent=$1 #passed argument
    local available_wh=$(echo "scale=2; ($percent - $SAFETY_PERCENT) * $TOTAL_CAPACITY_WH / 100" | bc) # Calculate available Wh after safety buffer

    if (( $(echo "$available_wh <= 0" | bc -l) )); then       # Force immediate hibernate if below safety threshold
        echo 0
        return
    fi

    # Calculate hours then seconds
    local hours=$(echo "scale=2; $available_wh / $DRAIN_RATE_WATT" | bc)
    local seconds=$(echo "$hours * 3600" | bc | cut -d'.' -f1)

    local final_seconds=$(echo "$seconds * 1" | bc | cut -d'.' -f1) #do we need a percent increase or decrease here?
    
    # if reached below certain delay cap force hibernate
    if [[ $final_seconds -lt 300 ]]; then
        final_seconds=0
    fi
    
    echo $final_seconds
}


s3_detect(){
#determine manual or rtc wake using time based calculation (better methods are welcomed)
while [[ -f /tmp/sulockfile ]]
do
refresh_values
calculate_delay $percent >/dev/null
local delay=$(calculate_delay $percent)

[[ "$delay" -ne 0 ]] && echo "next delay ${delay} at ${percent}%"
[[ "$delay" -eq 0 ]] && echo "low threshold no more suspend"

local secnow=$(date +%s)
local secafterdelay=$((secnow + delay))

battery_action #check before resuspend //remove sudo if kept for testing ...!

[[ "$delay" -ne 0 ]] && rtcwake -m mem -s $delay #execution stops here and countinues after wake in a suspend cycle

local secafterwake=$(date +%s) #tested to be a good solution despite time basing when scaled to the long delay seconds (and will set the fallback atleast 60 sec)
local tolsecafterwake=$((secafterwake + 2)) #tolerance time 

if [ $secafterdelay -lt $tolsecafterwake ]; then
[[ "$delay" -ne 0 ]] && echo "RTC wake"
#s3_detect #recurse till manual delay (looping is better)
else
echo "manual wake" &&  rm -f /tmp/sulockfile && echo "s3 wakeup done,lockfile cleared"  #remove sudo if kept for testing ...!
exit 0 #since timer will run it again and can comfortably quit here
fi
done
}


get_battery_info #running to get percent and subsequent delay repeated with timer
percent=$LEVEL
	if [[ -z "$percent" ]] || ! [[ "$percent" =~ ^[0-9]+$ ]]; then
            echo "Error: Could not read battery percentage."
            exit 1
    fi    

#-----------


#logic start
#detect if the lockfile is present in a tmpfs created using a suspend wrapper and execute (need to clear lockfile later)
#important decide the initial timer or add error handling to prevent suspend loop 
if [[ -f /tmp/sulockfile ]]; then #potential error :if suspend was woken up before the helper wrapper completed its first wake therell be a loop (fix needed)
s3_detect
fi

[ "$STATUS" != "Discharging" ] || [ "$LEVEL" -gt "$WARN" ] && exit 0 # exit quickly if charging 

battery_action #normal low battery flow
