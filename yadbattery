get_battery_percent() {
    local capacity_file="$BATTERY_PATH/capacity"
    if [[ -f "$capacity_file" ]]; then
        cat "$capacity_file"
    else
        # Fallback calculation
        local energy_now=$(cat "$BATTERY_PATH/charge_now" 2>/dev/null || echo 0)
        local energy_full=$(cat "$BATTERY_PATH/charge_full_design" 2>/dev/null || echo 0)
        if [[ $energy_full -gt 0 ]]; then
            echo $(( energy_now * 100 / energy_full ))
        else
            echo 0
        fi
    fi
}
