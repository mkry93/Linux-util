#current capacity and status logic
#-----------------
get_battery_info() {
    LEVEL=$(cat "$BATTERY_PATH/capacity")
    STATUS=$(cat "$BATTERY_PATH/status")
}
#-----------------

calculate_delay() {
#refresh_values #prevent unnecessary calls + mock support + logging (how?)
    local percent=$1 #passed argument
    local available_wh=$(echo "scale=2; ($percent - $SAFETY_PERCENT) * $TOTAL_CAPACITY_WH / 100" | bc) # Calculate available Wh after safety buffer

    if (( $(echo "$available_wh <= 0" | bc -l) )); then       # Force immediate hibernate if below safety threshold
        echo 0
        return
    fi

    # Calculate hours then seconds
    local hours=$(echo "scale=2; $available_wh / $DRAIN_RATE_WATT" | bc)
    local seconds=$(echo "$hours * 3600" | bc | cut -d'.' -f1)

    local final_seconds=$(echo "$seconds * 0.90" | bc | cut -d'.' -f1) #do we need a percent increase or decrease here?
    
    # if reached below certain delay cap force hibernate
    if [[ $final_seconds -lt 600 ]]; then
        final_seconds=0
    fi
    
    echo $final_seconds
}


s3_detect(){
#determine manual or rtc wake using time based calculation (better methods are welcomed)
while [[ -f $LOCK ]]
do
refresh_values
calculate_delay $percent >/dev/null
local delay=$(calculate_delay $percent)

[[ "$delay" -ne 0 ]] && echo "next delay ${delay} at ${percent}%"
[[ "$delay" -eq 0 ]] && echo "low threshold no more suspend"

local secnow=$(date +%s)
local secafterdelay=$((secnow + delay))

battery_action #check before resuspend

[[ "$delay" -ne 0 ]] && rtcwake -m mem -s $delay #execution stops here and countinues after wake in a suspend cycle

local secafterwake=$(date +%s) #tested to be a good solution despite time basing when scaled to the long delay seconds (and will set the fallback atleast 60 sec)
local tolsecafterwake=$((secafterwake + 2)) #tolerance time 

if [ $secafterdelay -lt $tolsecafterwake ]; then
[[ "$delay" -ne 0 ]] && echo "RTC wake"
[[ "$delay" -eq 0 ]] && exit 0

#s3_detect looping till manual delay

else
echo "manual wake" &&  rm -f $LOCK && echo "s3 wakeup done,lockfile cleared" 
exit 0 #since timer will run it again and can comfortably quit here
fi
done
}


get_battery_info #running to get percent and subsequent delay repeated with timer
percent=$LEVEL
	if [[ -z "$percent" ]] || ! [[ "$percent" =~ ^[0-9]+$ ]]; then
            echo "Error: Could not read battery percentage."
            exit 1
    fi    

#-----------


#logic start - detect if the lockfile is present

if [[ -f $LOCK ]]; then
s3_detect
fi

[ "$STATUS" != "Discharging" ] || [ "$LEVEL" -gt "$WARN" ] && exit 0 # exit quickly if charging 

battery_action #normal low battery flow
