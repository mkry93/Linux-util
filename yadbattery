#!/bin/bash

# Check if running as root
if [ "$(id -u)" -ne 0 ]; then # Not root - attempt privilege escalation via pkexec
command -v pkexec >/dev/null 2>&1 || { echo "pkexec is required"; exit 1; } #no pkexec script exits
    if ! pkexec "$0" "$@"; then #Failed to gain root privileges via pkexec
        exit 1
    fi
    exit $?   # If pkexec succeeds, it replaces this process with a new root process and this line wont exec, else a PID will be caught
fi

# From this point, we should be running as root (root timer starts here)

#solid set values
LOW=15 #currently effectively hibernates at low,sets delay=0 to battery_action remove lock and hibernate
WARN=20
SAFETY_PERCENT=10 #when reaches this % (if ocassionally), then the script calls immediate hibernation
LOCK=/tmp/sulockfile #should be a tmpfs (cleared on reboot not s4/s3 states..!)

GAINED_ROOT_VIA_PKEXEC=false # Check if we got here via pkexec (PKEXEC_UID is set by pkexec)
if [ -n "$PKEXEC_UID" ]; then
    GAINED_ROOT_VIA_PKEXEC=true
fi

# Only write lockfile if we gained root via pkexec
# If already started as root, skip lockfile logic entirely
if [ "$GAINED_ROOT_VIA_PKEXEC" = true ]; then
    if [ ! -f "$LOCK" ]; then
        touch "$LOCK"
        echo "No lockfile detected, wrote lock"
    else
        echo "Lockfile exists... continue suspend"
    fi
fi

#Check dependencies
command -v bc >/dev/null 2>&1 || { echo "bc is required"; exit 1; }
command -v yad >/dev/null 2>&1 || { echo "yad is required"; exit 1; }
command -v upower >/dev/null 2>&1 || { echo "upower is required"; exit 1; }

#find the battery using sysfs or error out
#may fail for multi-battery (please help in testing and reporting) or if your system labels power supply as BAT (unlikely)
for B in /sys/class/power_supply/BAT?; do
    [ -d "$B" ] && BATTERY_PATH="$B" && break
done
[ -z "$BATTERY_PATH" ] && echo "didnt find Battery path" && exit 1   #exit if not found (need to add a error message)


# ----------------
#function declarations


get_xauth(){
#getting the xauth  magic-cookie to display the yad dialogue //sorted according to current graphical user
#have noticed missing dialogues in multi-user need cause and fix
for user in $(who | grep "(:[0-9]" | cut -d' ' -f1 | head -1); do
    cp "/home/$user/.Xauthority" /root/.Xauthority.tmp 2>/dev/null && {
        export XAUTHORITY=/root/.Xauthority.tmp
        break
    }
done
}

#refresh dynamic values when needed
refresh_values(){
TOTAL_CAPACITY_WH=$(upower -i /org/freedesktop/UPower/devices/battery_BAT1 | grep -P -o 'energy-full:\s*\K[\d.]+\s') #need no dependency way to get Wh (critical...!)
DRAIN_RATE_WATT=$(upower -i /org/freedesktop/UPower/devices/battery_BAT1 | grep -P -o 'energy-rate:\s*\K[\d.]+')  #May becomes zero at times (1.when charger disconnected)
if [[ -z "$DRAIN_RATE_WATT" ]] || (( $(echo "$DRAIN_RATE_WATT <= 0" | bc -l) )); then #bc for float calculation but spawns a subshell (need faster impl)
        DRAIN_RATE_WATT=10.0  # Conservative fallback to prevent crash (optional another way for dynamism (portability:option))
    fi
}

battery_action(){
#no dialogue countdown at critical battery
get_battery_info
get_xauth #call each time the elif dialogue needs to run
if [ "$LEVEL" -le "$LOW" ] && [ "$STATUS" = "Discharging" ]; then
rm -f $LOCK && systemctl hibernate -i
exit 0
#hibern && rm -f $LOCK && exit 0  #custom hibernate script
#fi
elif [ "$LEVEL" -le "$WARN" ] && [ "$STATUS" = "Discharging" ] && [[ ! -f $LOCK ]]; then #last one for no dialogue durin a suspend run
# Show non-interactive progress dialog that auto-closes after seconds
(
    for i in $(seq 10 -1 1); do
        percent=$(( (10-i)*100/10 ))
        echo "$percent"
        echo "# Sleeping in $i seconds (Battery: $LEVEL%)"
        sleep 1
    done
) | yad --progress \
    --title="Low Battery: $LEVEL%" \
    --text="Automatic Sleep...Connect power to terminate" \
    --timeout=10 \
    --no-cancel \
    --width=300 \
    --undecorated \
    --no-buttons \
    --auto-close

fi

get_battery_info #check if plugged-in else hibernate
sleep 1 #to avoid potential execute before recheck situation

if [ "$LEVEL" -le "$WARN" ] && [ "$STATUS" = "Discharging" ]; then
[[ -f $LOCK ]] && echo "Warning :lock file detected at this stage?,removing for safety" && rm -r $LOCK
systemctl hibernate -i && exit 0 #rationale:if the person was present would have plugged-in (assumption) prevent unnecesary hibernate 
#also this wont(shoudnt) run in a suspend loop so no lockfile removals needed
#hibern  #custom hibernate script to manage chromium hang
fi
}

